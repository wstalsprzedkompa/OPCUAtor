# REST server
REST_HOST=0.0.0.0
REST_PORT=9500

# ABB charger OPC UA endpoint, for example:
# OPCUA_ENDPOINT=opc.tcp://192.168.1.50:4840
OPCUA_ENDPOINT=

# Optional authentication
# OPCUA_USERNAME=
# OPCUA_PASSWORD=

# Optional security. This accepts asyncua's security string format, for example:
# Basic256Sha256,SignAndEncrypt,certs/client_cert.pem,certs/client_key.pem,certs/server_cert.pem
# Basic256Sha256,Sign,certs/client_cert.pem,certs/client_key.pem,certs/server_cert.pem
OPCUA_SECURITY_STRING=

# Browsing limits
OPCUA_MAX_DEPTH=8
OPCUA_MAX_NODES=5000
OPCUA_REQUEST_TIMEOUT=30
