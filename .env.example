# REST server
REST_HOST=0.0.0.0
REST_PORT=9500

# OPC UA endpoint, for example:
# OPCUA_ENDPOINT=opc.tcp://OR2HPM-EH9-9999-023:4840/OPCUA/LithosServer
OPCUA_ENDPOINT=

# Optional authentication
# OPCUA_USERNAME=
# OPCUA_PASSWORD=

# Optional application URI. If you generate the certificate with the default script
# on this machine, copy the printed Application URI here.
OPCUA_APPLICATION_NAME=OPCUAtor
# OPCUA_APPLICATION_URI=urn:hostname:OPCUAtor
OPCUA_PRODUCT_URI=urn:opcuator:client

# Optional server URI. If /endpoints returns server_application_uri and the server
# rejects session/browse requests, copy that value here.
# OPCUA_SERVER_URI=

# Optional security.
# Use None or leave empty for SecurityPolicy#None.
OPCUA_SECURITY_STRING=None
#
# For secure endpoints this accepts asyncua's security string format, for example:
# Basic256Sha256,SignAndEncrypt,certs/uaexpert.der,certs/uaexpert_key.pem
# Basic256Sha256,Sign,certs/uaexpert.der,certs/uaexpert_key.pem
#
# UaExpert certificate/key variant:
# OPCUA_SECURITY_STRING=Basic256Sha256,SignAndEncrypt,certs/uaexpert.der,certs/uaexpert_key.pem

# Some embedded servers return an empty UserIdentityTokens list even though they
# accept Anonymous sessions. Keep this enabled to try Anonymous anyway.
OPCUA_ASSUME_ANONYMOUS_IF_NO_TOKENS=true

# Browsing limits
OPCUA_MAX_DEPTH=8
OPCUA_MAX_NODES=5000
OPCUA_BROWSE_REFERENCES_PER_NODE=1000
OPCUA_REQUEST_TIMEOUT=30
